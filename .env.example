# ============================================================
# 所有 key 都是【可选】的。
# 默认数据源 GDELT + RSS 无需任何 key，开箱即用。
# 想启用某个付费源：① 在这里填 key ② 在 config.yaml 把对应 source 设为 enabled: true
# ============================================================

# Alpha Vantage（可选）— https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Finnhub（可选）— https://finnhub.io/register
FINNHUB_KEY=
FINNHUB_WEBHOOK_SECRET=

# NewsAPI（可选）— https://newsapi.org/register
NEWSAPI_KEY=

# CryptoPanic（可选，加密专属舆情，自带多空投票）— https://cryptopanic.com/developers/api/
CRYPTOPANIC_KEY=

# 免费、无需 key、默认启用：
#   - GDELT 2.0  全球新闻（https://www.gdeltproject.org/）
#   - RSS 直采    CoinDesk / Cointelegraph / Investing / WSJ 等公开 RSS
